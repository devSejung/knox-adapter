{
  "name": "platformclaw-knox-adapter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Knox adapter skeleton for PlatformClaw gateway integration",
  "scripts": {
    "dev": "node --import tsx src/server.ts",
    "start": "node --import tsx src/server.ts",
    "mock:proxy": "node --import tsx src/mock-proxy.ts",
    "mock:gateway": "node --import tsx src/mock-gateway.ts",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "ws": "^8.18.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
